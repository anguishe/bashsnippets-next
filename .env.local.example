# ------------------------------------------------------------------------------
# bashsnippets-next — environment reference
# ------------------------------------------------------------------------------
# HEADS UP: as of this commit the app reads ZERO environment variables. Every
# value below is currently HARDCODED in the source (see the file noted on each
# line). So a .env.local does nothing yet — this file documents the config this
# site uses, and is ready to wire up IF you migrate those constants to env.
#
# None of these are secrets — GA/AdSense/IndexNow IDs and affiliate URLs are all
# public by nature. There are no private keys in this project.
#
# Usage: copy to .env.local (gitignored) and fill in. This .example IS committed.
#   cp .env.local.example .env.local
# ------------------------------------------------------------------------------

# Canonical site origin — no trailing slash.
# Currently: `const SITE_URL = 'https://bashsnippets.xyz'` repeated in ~20 files
# (src/app/page.tsx, snippets/[slug]/page.tsx, rss.xml/route.ts, guides/*, ...).
NEXT_PUBLIC_SITE_URL=https://bashsnippets.xyz

# Google Analytics 4 measurement ID.
# Currently hardcoded in src/app/layout.tsx.
NEXT_PUBLIC_GA_ID=G-6B01TGE8XS

# Google AdSense publisher ID.
# Currently hardcoded in src/app/layout.tsx and src/components/AdSlot.tsx.
# (Ad units are flag-disabled pending AdSense approval — see CLAUDE.md.)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-5399156622542127

# IndexNow key for post-deploy URL submission (Bing/Yandex).
# Verification file lives at public/<key>.txt; the key is also in the
# post-deploy curl in CLAUDE.md. Used server/CLI-side, so NOT NEXT_PUBLIC.
INDEXNOW_KEY=a7fae2a4e86d4822ab3f636599173c8f

# ------------------------------------------------------------------------------
# NOT env vars (intentionally): affiliate URLs.
# CLAUDE.md mandates these stay hardcoded in src/components/AffiliateBox.tsx
# ("never inline raw affiliate URLs elsewhere"). Listed here for reference only:
#   DigitalOcean: https://m.do.co/c/7a196437764c
#   Namecheap:    https://namecheap.pxf.io/c/7260430/1632743/5618
# ------------------------------------------------------------------------------
